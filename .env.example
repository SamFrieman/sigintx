# ──────────────────────────────────────────────────────────────────────────────
# SIGINTX — Environment Configuration Template
# Copy this file to .env and fill in every value before deploying.
#   cp .env.example .env
# The .env file must NEVER be committed to version control.
# ──────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL credentials for the production database.
# The POSTGRES_PASSWORD value must match DATABASE_URL below.
POSTGRES_USER=sigintx
POSTGRES_PASSWORD=change-me-strong-password-here

# Full async DSN used by the backend and workers.
# Format: postgresql+asyncpg://<user>:<password>@<host>/<db>
DATABASE_URL=postgresql+asyncpg://sigintx:change-me-strong-password-here@postgres/sigintx


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password-here
REDIS_URL=redis://:change-me-redis-password-here@redis:6379


# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-hex-string

# Set to true ONLY during local development — disables all token checks.
AUTH_DISABLED=true

# Optional: override the auto-generated first-boot admin password.
# If left empty, a random 20-char password is generated and printed to stdout.
# ADMIN_PASSWORD=your-strong-admin-password


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (backend env var).
# Example for a custom domain: https://sigintx.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Frontend env vars (VITE_ prefix = available at build time) ───────────────
# URL of the deployed backend API (e.g. your Render service URL).
# Leave empty for local dev — the Vite proxy handles routing automatically.
# Example: https://sigintx-api.onrender.com
VITE_API_URL=

# Set to "true" to skip the login screen entirely (public demo deployments).
# Must match AUTH_DISABLED on the backend.
VITE_AUTH_DISABLED=true


# ── AI Providers (optional — at least one enables AI features) ────────────────
# Groq (free tier available): https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (pay-per-token, many models): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Generic OpenAI-compatible endpoint (e.g. local vLLM, LM Studio, Ollama proxy)
# LLM_API_URL=http://localhost:11434/v1
# LLM_API_KEY=


# ── Telegram Alerts (optional) ───────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── Threat Intelligence APIs (optional) ──────────────────────────────────────
# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=
